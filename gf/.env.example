# QQ Bot - AI Girlfriend Configuration
# Copy this file to .env and fill in your values

# ==========================================
# LLM API Configuration (Kimi — text + vision)
# ==========================================
LLM_PROVIDER=kimi
LLM_API_KEY=your-moonshot-api-key-here
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=moonshot-v1-8k
LLM_VISION_MODEL=moonshot-v1-8k-vision-preview
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.9

# ==========================================
# NapCatQQ Configuration
# ==========================================
NAPCAT_BASE_URL=http://127.0.0.1:3000
NAPCAT_WS_URL=ws://127.0.0.1:3001
NAPCAT_ACCESS_TOKEN=

# ==========================================
# Bot Configuration
# ==========================================
BOT_QQ=123456789
BOT_NAME=小暖
STICKER_FREQUENCY=0.4
THINKING_DELAY_MIN=1
THINKING_DELAY_MAX=4

# ==========================================
# Admin & Sticker Management
# ==========================================
# Admin QQ number (can add/remove stickers via chat commands)
ADMIN_QQ=

# ==========================================
# Server Configuration
# ==========================================
HOST=127.0.0.1
PORT=8000

# ==========================================
# Scheduler Configuration
# ==========================================
SCHEDULER_ENABLED=true
DEFAULT_CLINGINESS=normal
MORNING_START=7
MORNING_END=10
EVENING_START=21
EVENING_END=0

# ==========================================
# Data Storage
# ==========================================
DATA_DIR=./data
STICKERS_DIR=./stickers
